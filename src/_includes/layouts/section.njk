---
layout: layouts/base
pageType: section
---
<div class="page-hero">
  <div class="page-wrapper">
    <p class="page-hero__subtitle">Section</p>
    <h1 class="page-hero__title">{{ title }}</h1>
  </div>
</div>

<div class="page-wrapper content-area" style="padding-top: var(--space-xl);">
  {% include "components/breadcrumb.njk" %}

  <div class="prose">
    {{ content | removeH1 | safe }}
  </div>

  {# List all subsections under this section #}
  {% set myUrl = page.url %}
  {% set subs = collections.subsections | subsectionsFor(myUrl) %}
  {% if subs.length %}
  <section class="related-articles" aria-label="Subsections">
    <p class="related-articles__heading">Topics in this section</p>
    <div class="sections-grid">
      {% for sub in subs %}
      <div class="card">
        <a href="{{ sub.url }}" class="card__title card__title--link">{{ sub.data.title or sub.fileSlug }}</a>
        {# List leaf articles under this subsection #}
        {% set subArticles = collections.articles | articlesFor(sub.url) %}
        {% if subArticles.length %}
        <ul class="link-list">
          {% for art in subArticles %}
          <li><a href="{{ art.url }}">{{ art.data.title or art.fileSlug }}</a></li>
          {% endfor %}
        </ul>
        {% else %}
        <p class="card__desc">Overview and guides coming soon.</p>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}
</div>

