<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or site.site.description }}">
  <meta name="theme-color" content="{{ site.site.themeColor }}">

  <!-- Canonical -->
  <link rel="canonical" href="{{ site.site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ site.site.name }}">
  <meta property="og:type" content="{% if pageType == 'article' %}article{% else %}website{% endif %}">
  <meta property="og:title" content="{{ title or site.site.name }}">
  <meta property="og:description" content="{{ description or site.site.description }}">
  <meta property="og:url" content="{{ site.site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.site.url }}/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="en_US">

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.site.name }}">
  <meta name="twitter:description" content="{{ description or site.site.description }}">
  <meta name="twitter:image" content="{{ site.site.url }}/og-image.png">

  <!-- PWA / Apple -->
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="{{ site.site.shortName }}">
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">

  <title>{% if title and title !== site.site.name %}{{ title }} | {{ site.site.shortName }}{% else %}{{ site.site.name }}{% endif %}</title>

  <!-- Icons -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="manifest" href="/manifest.json">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/main.css?v={{ assets.v }}">

</head>
<body>
  {% include "components/header.njk" %}

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "components/footer.njk" %}

  <!-- Scripts -->
  <script src="/js/nav.js?v={{ assets.v }}" defer></script>
  <script src="/js/copy-code.js?v={{ assets.v }}" defer></script>
  <script src="/js/checkbox.js?v={{ assets.v }}" defer></script>
  <script src="/js/accordion.js?v={{ assets.v }}" defer></script>
  <script src="/js/main.js?v={{ assets.v }}" defer></script>
</body>
</html>
