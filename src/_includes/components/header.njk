<nav class="site-header" aria-label="Site header">
  <div class="header-inner">
    <a href="/" class="site-logo" aria-label="{{ site.site.name }} home">
      <img src="/icons/logo.svg" alt="" class="site-logo__img" width="36" height="36" aria-hidden="true">
      <span class="site-logo__text">GIS CLI<br>Toolcraft</span>
    </a>

    <button class="nav-toggle" aria-controls="site-nav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
    </button>

    <nav id="site-nav" class="site-nav" aria-label="Main navigation">
      {% for section in site.sections %}
        <a href="{{ section.url }}" class="site-nav__link">
          <span class="nav-icon" aria-hidden="true">{{ section.icon }}</span>
          <span>{{ section.title }}</span>
        </a>
      {% endfor %}
    </nav>
  </div>
</nav>

