<footer class="site-footer" aria-label="Site footer">
  <div class="page-wrapper">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-brand__logo" aria-label="{{ site.site.name }} home">
          <img src="/icons/logo.svg" alt="" width="32" height="32" aria-hidden="true">
          <span class="footer-brand__name">GIS CLI Toolcraft</span>
        </a>
        <p class="footer-brand__desc">{{ site.site.description }}</p>
      </div>

      {% for section in site.sections %}
      <div class="footer-nav">
        <p class="footer-nav__heading">{{ section.title }}</p>
        <ul class="footer-nav__list">
      {% set sectionSlug = section.url %}
      {% for sub in collections.subsections %}
        {% if sub.url and sectionSlug and (sub.url.indexOf(sectionSlug) === 0) %}
        <li><a href="{{ sub.url }}">{{ sub.data.title or sub.fileSlug }}</a></li>
        {% endif %}
      {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>

    <div class="footer-bottom">
      <p>&copy; {% year %} {{ site.site.name }}</p>
      <a class="footer-github"
         href="https://github.com/batch-processing-geospatial-cli-tools"
         aria-label="Source and organisation on GitHub"
         rel="noopener" target="_blank">
        <svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true" focusable="false" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.65-.89-3.65-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

